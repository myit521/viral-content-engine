# ==================== 数据库 ====================
DATABASE_URL=sqlite:///./data/app.db

# ==================== AI 基础配置 ====================
# 必填：你的 AI 服务商 API 密钥
OPENAI_API_KEY=
# API 基础 URL（根据服务商调整）
OPENAI_BASE_URL=https://api.openai.com/v1
# 默认模型名称
DEFAULT_MODEL_NAME=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2
AI_ALLOW_MOCK_FALLBACK=true
PROMPT_ROOT=shared/contracts/prompts
LOG_LEVEL=INFO

# ==================== AI 模型提供商 ====================
# 可选值: openai, deepseek, dashscope(通义千问), zhipu(智谱), custom
AI_PROVIDER=openai

# ==================== 分场景模型配置 ====================
# 分析任务：快速 + 低成本（内容分析、特征提取）
AI_ANALYSIS_MODEL=gpt-4.1-mini

# 脚本生成：高质量（视频脚本、标题、分镜）
AI_GENERATION_MODEL=gpt-4.1

# 模板归纳：中等质量（聚类分析、模板提取）
AI_TEMPLATE_INDUCTION_MODEL=gpt-4.1-mini

# 文本预处理：快速模型（HTML清理、格式转换）
AI_PREPROCESSING_MODEL=gpt-4.1-mini

# Fallback 模型（主模型失败时降级使用）
AI_FALLBACK_MODEL=gpt-4.1-mini

# ==================== 缓存配置 ====================
CACHE_ENABLED=true
CACHE_BACKEND=memory
CACHE_DEFAULT_TTL_SECONDS=60
CACHE_HEALTH_TTL_SECONDS=15
CACHE_PLATFORMS_TTL_SECONDS=300
CACHE_TEMPLATES_TTL_SECONDS=120
CACHE_AI_TTL_SECONDS=3600

# ==================== 采集配置 ====================
CRAWL_MAX_CONCURRENT_TASKS=2
CRAWL_TASK_TIMEOUT_SECONDS=300
CRAWL_MAX_RETRY_COUNT=3
CRAWL_RETRY_EXPONENTIAL_BASE=60
CRAWL_TEMP_USER_DATA_DIR_PREFIX=
CRAWL_RAW_OUTPUT_ROOT=data/raw
CRAWL_LOGS_DIR=logs
CRAWL_PERSISTENT_BROWSER_STATE_ROOT=data/browser_state

# ==================== MediaCrawler 集成 ====================
MEDIACRAWLER_EXECUTABLE=mediacrawler
MEDIACRAWLER_PROJECT_DIR=external/MediaCrawler
MEDIACRAWLER_ENABLE_REAL=false
MEDIACRAWLER_FALLBACK_MOCK=true

# ==================== 网络 / 代理 ====================
CRAWL_PROXY_POOL=
CRAWL_VERIFICATION_WEBHOOK=
